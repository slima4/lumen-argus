# lumen-argus — Docker Compose environment overrides
#
# Copy this file to .env to customize ports, dashboard password, or Pro license:
#
#   cp .env.example .env
#   # edit values
#   docker compose up -d
#
# .env is gitignored — your values stay local.

# ---- Host port mapping ----
# Override these if 8080/8081 are already in use on your machine.
# The container always listens on 8080/8081 internally; only the host side changes.
LUMEN_ARGUS_PROXY_PORT=8080
LUMEN_ARGUS_DASH_PORT=8081

# ---- Dashboard password (optional) ----
# Empty = open access. Set to any string to require Basic Auth on the dashboard.
LUMEN_ARGUS_DASHBOARD_PASSWORD=

# ---- Pro license (optional) ----
# Required only when running the lumen-argus-pro image. Ignored by the community image.
# LUMEN_ARGUS_LICENSE_KEY=
